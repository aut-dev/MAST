{
  "env": {
    "browser": true,
    "node": true,
    "es6": true
  },
  "parser": "@babel/eslint-parser",
  "parserOptions": {
    "ecmaVersion": 6,
    "sourceType": "module",
    "requireConfigFile": false,
  },
  "extends": "eslint:recommended",
  "rules": {
    "no-undef": "warn",
    "indent": ["error", 2]
  }
}