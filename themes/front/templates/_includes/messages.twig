{% set messages = messages ?? [] %}
{% set message = craft.app.session.getFlash('notice', false, true) %}
{% if message %}
    {% set messages = messages|merge([{type: 'success', message: message}]) %}
{% endif %}
{% set message = craft.app.session.getFlash('error', false, true) %}
{% if message %}
    {% set messages = messages|merge([{type: 'danger', message: message}]) %}
{% endif %}

<div class="position-fixed toast-container" id="global-messages">
    {% for message in messages %}
        <div class="toast bg-{{ message.type }} align-items-center text-white border-0" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="4000">
            <div class="d-flex">
                <div class="toast-body">
                    {{ message.message|raw }}
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    {% endfor %}
</div>
