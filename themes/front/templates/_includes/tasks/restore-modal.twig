<div class="modal fade" tabindex="-1" id="restore-task-modal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post">
                {{ actionInput('entries/save-entry') }}
                {{ hiddenInput('entryId', task.id) }}
                {{ successMessageInput('Task has been restored'|t('site')) }}
                {{ hiddenInput('fields[archive]', 0) }}
                {{ redirectInput('/tasks') }}
                {{ csrfInput() }}
                <div class="modal-header">
                    <h5 class="modal-title">{{ 'Restore task'|t }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>{{ 'Restore this task as it was when it was archived'|t }}</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Close'|t }}</button>
                    <button type="submit" class="btn btn-primary">
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true" style="display: none;"></span>
                        {{ 'Restore'|t }}
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
