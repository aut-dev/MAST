{% import "_helpers/images" as images %}

{% set started = currentUser.timerStarted(task) %}
{% set daily_task = task.dailyTask %}
{% set is_active = daily_task and daily_task.isActive %}
{% set status = task.taskStatus %}
{% set length = task.length %}
{% set progress = 0 %}
{% set persec = 0 %}

{% if daily_task %}
    {% set length = daily_task.length %}
    {% if daily_task.isActive and task.timeBased %}
        {% set progress = daily_task.getProgress(true) %}
        {% set persec = 1 / length * 100 %}
    {% endif %}
{% endif %}

<a class="text-body task-wrapper" href="{{ task.url }}">
    <div class="square task p-3 bg-task rounded" data-timer-started="{{ started ? 1 : 0 }}" data-status="{{ status }}" data-id="{{ task.id }}" data-progress="{{ progress }}" data-persec="{{ persec }}" data-active="{{ is_active ? 1 : 0 }}" data-paused="{{ task.paused ? 1 : 0 }}" {% if task.backgroundColor %}style="background-color: {{ task.backgroundColor }}"{% endif %}>
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h4 class="m-0 text-truncate">{{ task.title }}</h4>
            <div class="d-flex align-items-center">
                <small class="if-status-paused">
                    {{ 'Paused'|t }}
                </small>
                <span class="complete-tick if-status-complete ms-3"><i class="fa-solid fa-check"></i></span>
            </div>
        </div>
        <p class="text-light mb-0">
            {% if not task.timeBased %}
                One off
            {% else %}
                {{ task.taskType|ucfirst }} than {{ (length / 60)|round }} min
            {% endif %}
        </p>
        {% if task.timeBased %}
            <div class="if-not-inactive-or-paused">
                <div class="progress">
                    <div class="progress-bar" role="progressbar" style="width: {{ progress }}%" aria-valuenow="{{ progress }}" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
            </div>
        {% endif %}
        <p class="if-status-active m-0">
            {{ 'Minutes until deadline:'|t }} <span class="countdown">{{ task.todayDeadline|minutesToNow }}</span>
        </p>
        <div class="actions d-flex justify-content-between align-items-center mt-2">
            {% if task.timeBased %}
                <span class="js-start-timer text-purple2 fs-5" data-textstart="{{ 'Start'|t }}" data-textstop="{{ 'Stop'|t }}">
                    {% if started %}
                        {{ 'Stop'|t }}
                    {% else %}
                        {{ 'Start'|t }}
                    {% endif %}
                </span>
            {% else %}
                <span class="if-active js-task-done text-purple2 fs-5 {% if daily_task and daily_task.done %}done{% endif %}">
                    Done
                </span>
            {% endif %}
            <span class="if-active fs-4">${{ task.committed.getAmount / 100 }}</span>
        </div>
        {% if getenv('CRAFT_ENVIRONMENT') == 'local' %}
            {# <p>Today is {{ currentUser.now|date('d/m/Y H:i', currentUser.timezone) }}</p> #}
        {% endif %}
    </div>
</a>