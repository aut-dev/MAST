{% set started = currentUser.timerStarted(task.id) %}
{% set status = task.taskStatus %}

{% set progress = 0 %}
{% set persec = 0 %}
{% if task.isActive %}
    {% set spent = task.getTimeSpent(null, true) %}
    {% set progress = spent / task.duration * 100 %}
    {% set persec = 1 / task.duration * 100 %}
{% endif %}

<div class="square task p-3 bg-task rounded {% if started %}timer-started{% endif %}" data-status="{{ status }}" data-id="{{ task.id }}" data-active="{{ task.isActive }}" data-progress="{{ progress }}" data-persec="{{ persec }}">
    <h4 class="mb-0">{{ task.title }}</h4>
    <p>{{ task.taskType|ucfirst }} than {{ (task.length / 60)|round }} min</p>
    <div class="inner">
        {% include "_includes/tasks/inner" %}
    </div>
    <div class="actions d-flex justify-content-between align-items-center">
        <a href="#" class="js-delete-task click-through" data-id="{{ task.id }}" data-bs-toggle="modal" data-bs-target="#delete-task-modal"><i class="fa-solid fa-trash click-through"></i></a>
        <i class="fa-solid fa-up-down-left-right handle"></i>
        <a href="{{ task.url }}" class="click-through"><i class="fa-solid fa-eye click-through"></i></a>
    </div>
</div>