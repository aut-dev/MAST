<div class="modal fade" tabindex="-1" id="edit-break-modal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form>
                <div class="modal-header">
                    <h5 class="modal-title" data-add-title="{{ 'Add a break'|t }}" data-edit-title="{{ 'Edit break'|t }}"></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    {% set section = craft.app.sections.getSectionByHandle('break') %}
                    {{ csrfInput() }}
                    {{ actionInput('entries/save-entry') }}
                    {{ hiddenInput('sectionId', section.id) }}
                    {{ hiddenInput('entryId', '') }}
                    <div class="form-group mb-3 field-title">
                        <label class="required">{{ 'Title'|t }}</label>
                        {{ input('text', 'title', '', {
                            class: 'form-control',
                            id: 'field-title'
                        }) }}
                    </div>
                    <div class="form-group mb-3 field-startDate">
                        <label for="startDate" class="required">{{ 'Start date'|t }}</label>
                        <input type="hidden" class="timezone" name="fields[startDate][timezone]" value="{{ currentUser.timezone }}">
                        <div>
                            {{ input('text', 'fields[startDate][date]', '', {
                                id: 'startDate',
                                class: 'form-control datepicker',
                                data: {
                                    options: {
                                        static: true,
                                        dateFormat: 'Y-m-d'
                                    }
                                }
                            }) }}
                        </div>
                    </div>
                    <div class="form-group mb-3 field-endDate">
                        <label for="endDate" class="required">{{ 'End date'|t }}</label>
                        <input type="hidden" class="timezone" name="fields[endDate][timezone]" value="{{ currentUser.timezone }}">
                        <div>
                            {{ input('text', 'fields[endDate][date]', '', {
                                id: 'endDate',
                                class: 'form-control datepicker',
                                data: {
                                    options: {
                                        static: true,
                                        dateFormat: 'Y-m-d'
                                    }
                                }
                            }) }}
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Close'|t }}</button>
                    <button type="submit" class="btn btn-primary">
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true" style="display: none;"></span>
                        {{ 'Save'|t }}
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
