{% import "_helpers/errors" as errors %}

{% set success_message = success_message ?? 'Your password has been updated'|t %}
{% set code = craft.app.request.getRequiredParam('code') %}
{% set redirect_to = redirect_to ?? craft.app.request.getQueryParam('redirectTo', '/login') %}

<form method="post" accept-charset="UTF-8">
    {{ csrfInput() }}
    {{ actionInput('users/set-password') }}
    {{ hiddenInput('code', code) }}
    {{ hiddenInput('id', id) }}
    {{ successMessageInput(success_message) }}
    {% if redirect_to %}
        {{ redirectInput(redirect_to) }}
    {% endif %}

    <div class="form-group mb-3">
        <label for="new-password" class="required">{{ 'New Password'|t('site') }}</label>
        {{ input('password', 'newPassword', null, {
            id: 'new-password',
            required: true,
            class: 'form-control bg-white-opaque'
        }) }}
        {{ errors.errorList(errors ?? []) }}
    </div>

    <div class="form-group mb-3 text-center">
        <button class="btn btn-primary" type="submit">{{ 'Submit'|t('site') }}</button>
    </div>
</form>
