{% set success_message = success_message ?? 'Please check your emails for a reset password link'|t %}
{% set redirect_to = redirect_to ?? craft.app.request.getQueryParam('redirectTo', '/login') %}

<form method="post" accept-charset="UTF-8">
    {{ csrfInput() }}
    {{ actionInput('users/send-password-reset-email') }}
    {{ successMessageInput(success_message) }}
    {% if redirect_to %}
        {{ redirectInput(redirect_to) }}
    {% endif %}
    <div class="form-group mb-3">
        <label for="loginName" class="required">{{ 'Email'|t('site') }}</label>
        {{ input('text', 'loginName', loginName ?? craft.app.user.rememberedUsername, {
            id: 'loginName',
            autocomplete: 'username',
            required: 'required',
            class: 'form-control'
        }) }}
        {% if errors is defined %}
            <div class="invalid-feedback">{{ errors.0 }}</div>
        {% endif %}
    </div>

    <div class="form-group mb-3 text-center">
        <button type="submit" class="btn btn-primary">{{ 'Submit'|t('site') }}</button>
    </div>
</form>
