<div class="modal fade" tabindex="-1" id="delete-timesheet-modal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form>
                {{ actionInput('elements/delete') }}
                {{ hiddenInput('elementId') }}
                {{ csrfInput() }}
                <div class="modal-header">
                    <h5 class="modal-title">{{ 'Delete time entry'|t }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>{{ 'This will delete the time entry, are you sure ?'|t }}</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Close'|t }}</button>
                    <button type="submit" class="btn btn-primary">
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true" style="display: none;"></span>
                        {{ 'Delete'|t }}
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>