{% extends "_layouts/matrix-content" %}
{% requireLogin %}

{% do craft.app.view.registerAssetBundle('themes\\front\\assets\\MyAccountPage') %}
{% set method = currentUser.getPaymentMethod() %}

{% block before_content %}
    {% if craft.app.request.getQueryParam("errorSubscription") %}
        <div class="container">
            <div class="alert alert-warning">
                You've reached your free 3 tasks trial, subscribe to be able to create more tasks
            </div>
        </div>
    {% endif %}
{% endblock %}

{% block after_content_matrix %}
    <div class="container container-small text-center">
        <h2 class="mb-3">{{ 'My Subscription'|t }}</h2>
        {% if currentUser.stripeSessionId %}
            <p>{{ 'Subscription status: {status}'|t('site', {
                status: currentUser.subscriptionStatus|capitalize
            }) }}</p>
            {% if currentUser.subscriptionExpires > now %}
                {% if currentUser.cancelAtPeriodEnd %}
                    <p>{{ 'Your subscription will be cancelled the {date}.'|t('site', {
                        date: currentUser.subscriptionExpires|date('d/m/Y', currentUser.timezone)
                    }) }}</p>
                {% else %}
                    <p>{{ 'Your subscription renews the {date}.'|t('site', {
                        date: currentUser.subscriptionExpires|date('d/m/Y', currentUser.timezone)
                    }) }}</p>
                {% endif %}
            {% else %}
                <p>{{ 'Your subscription has expired the {date}.'|t('site', {
                    date: currentUser.subscriptionExpires|date('d/m/Y', currentUser.timezone)
                }) }}</p>
            {% endif %}
            <form method="post">
                {{ actionInput('plugin-stripe/stripe/create-portal-session') }}
                {{ csrfInput() }}
                <button class="btn btn-primary" type="submit">{{ 'Manage my subscription'|t }}</button>
            </form>
        {% else %}
            <form method="post">
                {{ actionInput('plugin-stripe/stripe/create-checkout-session') }}
                {{ csrfInput() }}
                <button class="btn btn-primary" type="submit">{{ 'Pay for subscription'|t }}</button>
            </form>
        {% endif %}
        {% if method and method.card is defined %}
            <h2 class="my-3">{{ 'Payment method'|t }}</h2>
            <p>{{ '{type} ending in {ends}'|t('site', {
                type: method.card.brand|ucfirst,
                ends: method.card.last4
                }) }}{% if method.card.exp_year %}{{ ', expiring in {date}'|t('site', {
                    date: method.card.exp_month ~ '/' ~ method.card.exp_year
                }) }}{% endif %}</p>
        {% endif %}
        <h2 class="my-3">{{ 'Update details'|t }}</h2>
        <div class="d-flex justify-content-center">
            {% include "_includes/user/account-form" %}
        </div>
        <h2 class="my-3">{{ 'Password'|t }}</h2>
        <a href="#change-password-modal" class="btn btn-primary" type="button" data-bs-toggle="modal">{{ 'Change password'|t }}</a>
    </div>
    {% include "_includes/user/change-password-modal" %}
{% endblock %}