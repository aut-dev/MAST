{% extends "_layouts/entry" %}
{% requireLogin %}

{% do craft.app.view.registerAssetBundle('themes\\front\\assets\\AddTaskPage') %}

{% block content %}
    <div class="container">
        <h1 class="text-center">{{ entry.title }}</h1>
        <div class="d-flex justify-content-center">
            <form id="add-task-form">
                {{ csrfInput() }}
                {{ actionInput('plugin-tasks/tasks/save-blocks') }}
                <div class="form-group mb-3 field-name">
                    <label for="name" class="required">{{ 'Name'|t }}</label>
                    {{ input('text', 'name', '', {
                        id: 'name',
                        class: 'form-control'
                    }) }}
                </div>

                <div class="form-group mb-3 field-startDate">
                    <label for="startDate" class="required">{{ 'Start date'|t }}</label>
                    {{ input('text', 'startDate', now|date('Y-m-d'), {
                        id: 'startDate',
                        class: 'form-control datepicker',
                        data: {
                            options: {
                                minDate: now|date('Y-m-d'),
                            }
                        }
                    }) }}
                </div>

                <div class="form-group mb-3 field-length">
                    <label for="length" class="required">{{ 'Work block length (minutes)'|t }}</label>
                    {{ input('number', 'length', 10, {
                        id: 'length',
                        class: 'form-control',
                        min: 1,
                        step: 1
                    }) }}
                </div>

                <div class="form-group mb-3">
                    <label for="deadline" class="required">{{ 'Deadline'|t }}</label>
                    {{ input('text', 'deadline', '23:59', {
                        id: 'deadline',
                        class: 'form-control datepicker',
                        data: {
                            options: {
                                enableTime: true,
                                noCalendar: true,
                                time_24hr: true
                            }
                        }
                    }) }}
                </div>

                <div class="form-group mb-3 field-committed">
                    <label for="committed" class="required">{{ '$ committed per derail'|t }}</label>
                    {{ input('number', 'committed', 1, {
                        id: 'committed',
                        class: 'form-control',
                        min: 1,
                        step: 1
                    }) }}
                </div>

                <div class="form-group mb-3">
                    <button type="sumit" class="btn btn-primary">{{ 'Submit'|t }}</button>
                </div>
            </form>
        </div>
    </div>
{% endblock %}